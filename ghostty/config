theme = Dark Modern
background-opacity = 0.94

split-divider-color = "#666699"
unfocused-split-fill = "#444466"

macos-option-as-alt = left

# Save and restore the last session
window-save-state = always
shell-integration = detect
shell-integration-features = path
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# key bindings
keybind = super+arrow_down=goto_split:down
keybind = super+arrow_left=goto_split:left
keybind = super+arrow_right=goto_split:right
keybind = super+arrow_up=goto_split:up
keybind = super+y=redo
